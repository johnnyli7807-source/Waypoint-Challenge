# Backend (FastAPI)
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides — defaults are the latest Claude 4.x models
ANTHROPIC_MODEL_FAST=claude-sonnet-4-6
ANTHROPIC_MODEL_SMART=claude-opus-4-7

# Optional: where the SQLite job store lives. Default: data/modulus.db (relative to cwd).
# In production, prefer an absolute path so it survives cwd changes.
# MODULUS_DB_PATH=/var/www/modulus/data/modulus.db.
